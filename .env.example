# ==============================================================================
# FLEETINTEL MCP - VARIAVEIS DE AMBIENTE
# ==============================================================================
# Copie para .env e preencha os valores reais
# NUNCA commite o .env (ja esta no .gitignore)
# ==============================================================================

# ==============================================================================
# BANCO DE DADOS (PostgreSQL local via Docker)
# ==============================================================================
DATABASE_URL=postgresql+asyncpg://fleetintel:fleetintel_dev@127.0.0.1:5432/fleetintel
# Producao: postgresql+asyncpg://fleetintel:SENHA@127.0.0.1:5432/fleetintel

FLEETINTEL_DB_PASSWORD=fleetintel_dev
# Senha do PostgreSQL Docker (usada pelo docker-compose.local.yml)

# ==============================================================================
# REDIS (Cache)
# ==============================================================================
REDIS_URL=redis://localhost:6379/1
# db=1 para nao colidir com outros servicos usando db=0

# ==============================================================================
# MCP SERVER (HTTP Transport)
# ==============================================================================
MCP_AUTH_TOKEN=
# Bearer token para autenticacao do MCP HTTP server
# Gere com: openssl rand -hex 32
# Exemplo: MCP_AUTH_TOKEN=a1b2c3d4e5f6...

MCP_PORT=8888
# Porta do MCP HTTP server (padrao: 8888)

# ==============================================================================
# HUBQUEST API (Sync incremental de dados)
# ==============================================================================
HUBQUEST_API_KEY=
# Chave de API para acesso a HubQuest

HUBQUEST_API_URL=https://api.hubquest.com/v1
# URL base da API HubQuest

# ==============================================================================
# LLM (para query natural language - opcional)
# ==============================================================================
ANTHROPIC_API_KEY=
# Chave da API Anthropic (Claude) para consultas em linguagem natural

# ==============================================================================
# APLICACAO
# ==============================================================================
APP_ENV=development
DEBUG=true
ADMIN_API_KEY=
