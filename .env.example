# ==============================================================================
# FLEETINTEL MCP - ENVIRONMENT VARIABLES
# ==============================================================================
# 
# Este arquivo serve como template para configuração de variáveis de ambiente.
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env: cp .env.example .env
# 2. Preencha os valores reais das variáveis obrigatórias
# 3. NUNCA commite o arquivo .env (já está no .gitignore)
# 4. Mantenha este .env.example atualizado ao adicionar novas variáveis
# 
# SEGURANÇA:
# - Nunca use valores reais neste arquivo de exemplo
# - Rotacione suas chaves periodicamente
# - Use secrets managers em produção (Doppler, AWS Secrets Manager, etc.)
# 
# ==============================================================================

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================
APP_ENV=development
# Tipo: string | Obrigatório: sim
# Define o ambiente de execução (development, staging, production)

DEBUG=true
# Tipo: boolean | Obrigatório: não
# Habilita modo debug (não usar em produção)

PORT=8000
# Tipo: integer | Obrigatório: não
# Porta para o servidor FastAPI

# ==============================================================================
# API EXTERNA - CONSULTA DE VEÍCULOS
# ==============================================================================
VEHICLE_API_URL=https://api.example.com
# Tipo: string | Obrigatório: sim
# URL base da API de consulta de veículos

VEHICLE_API_KEY=sk_example_1234567890abcdef
# Tipo: string | Obrigatório: sim
# Chave de API para autenticação

# ==============================================================================
# SUPABASE (DATABASE)
# ==============================================================================
SUPABASE_URL=https://your-project.supabase.co
# Tipo: string | Obrigatório: sim
# URL do projeto Supabase

SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example
# Tipo: string | Obrigatório: sim
# Chave pública (anon key)

SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.service_role_example
# Tipo: string | Obrigatório: sim
# Chave de serviço (privilegiada)

# ==============================================================================
# REDIS (CACHE & QUEUES)
# ==============================================================================
REDIS_HOST=localhost
# Tipo: string | Obrigatório: sim
# Endereço do servidor Redis

REDIS_PORT=6379
# Tipo: integer | Obrigatório: não
# Porta do Redis (padrão: 6379)

REDIS_PASSWORD=your_redis_password
# Tipo: string | Obrigatório: não
# Senha para autenticação no Redis

# ==============================================================================
# EVOLUTION API (WHATSAPP)
# ==============================================================================
EVOLUTION_API_URL=http://localhost:3000
# Tipo: string | Obrigatório: sim
# URL da instância Evolution API

EVOLUTION_API_KEY=evolution_api_key_example
# Tipo: string | Obrigatório: sim
# Chave de API para autenticação

# ==============================================================================
# OPENAI (LLM)
# ==============================================================================
OPENAI_API_KEY=sk-example-1234567890abcdef
# Tipo: string | Obrigatório: sim
# Chave de API da OpenAI

OPENAI_MODEL=gpt-4-turbo
# Tipo: string | Obrigatório: não
# Modelo LLM padrão (padrão: gpt-4-turbo)

# ==============================================================================
# LANGFUSE (OBSERVABILITY) - OPTIONAL
# ==============================================================================
LANGFUSE_PUBLIC_KEY=pk-example-123
# Tipo: string | Obrigatório: não
# Chave pública Langfuse

LANGFUSE_SECRET_KEY=sk-example-456
# Tipo: string | Obrigatório: não
# Chave secreta Langfuse

LANGFUSE_HOST=https://cloud.langfuse.com
# Tipo: string | Obrigatório: não
# URL do Langfuse (cloud ou self-hosted)
