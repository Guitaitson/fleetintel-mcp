# =============================================================================
# FLEETINTEL MCP - ENVIRONMENT VARIABLES
# =============================================================================
# Copie para .env.local e preencha os valores

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
ENVIRONMENT=local  # local | staging | production
DEBUG=true
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL

# -----------------------------------------------------------------------------
# API EXTERNA (Frotas)
# -----------------------------------------------------------------------------
# OBRIGATÓRIO: URL base da API externa
FLEET_API_BASE_URL=https://api-externa.com/v1

# OBRIGATÓRIO: Chave de autenticação da API
FLEET_API_KEY=your-api-key-here

# Timeout em segundos para requests
FLEET_API_TIMEOUT=30

# Max retries em caso de falha
FLEET_API_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------
# OBRIGATÓRIO: URL do projeto Supabase
SUPABASE_URL=https://xxxxx.supabase.co

# OBRIGATÓRIO: Anon/Public key (para operações client-side)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OBRIGATÓRIO: Service role key (para operações server-side, MUITO SENSÍVEL)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Connection pool settings
SUPABASE_POOL_MIN_SIZE=1
SUPABASE_POOL_MAX_SIZE=10

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
# Host do Redis (localhost em dev, IP do VPS em prod)
REDIS_HOST=localhost

# Porta do Redis
REDIS_PORT=6379

# OBRIGATÓRIO EM PROD: Password do Redis
REDIS_PASSWORD=

# Database number (0-15)
REDIS_DB=0

# Max connections no pool
REDIS_MAX_CONNECTIONS=10

# TTL padrão em segundos (1 hora)
REDIS_DEFAULT_TTL=3600

# -----------------------------------------------------------------------------
# FASTAPI / MCP SERVER
# -----------------------------------------------------------------------------
# Host do servidor
SERVER_HOST=0.0.0.0

# Porta do servidor
SERVER_PORT=8000

# Prefixo da API
API_V1_PREFIX=/api/v1

# OBRIGATÓRIO: Secret key para JWT/sessions (gerar com: openssl rand -hex 32)
API_SECRET_KEY=generate-a-secure-random-key-here

# CORS origins (separados por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
# Requests por minuto por usuário
RATE_LIMIT_PER_MINUTE=60

# Requests por hora por usuário
RATE_LIMIT_PER_HOUR=1000

# Requests por dia por usuário
RATE_LIMIT_PER_DAY=10000

# -----------------------------------------------------------------------------
# QUERY GUARDRAILS
# -----------------------------------------------------------------------------
# Máximo de registros retornados por query
MAX_RECORDS_PER_QUERY=100

# Máximo de dias em um range de data
MAX_DATE_RANGE_DAYS=90

# -----------------------------------------------------------------------------
# SYNC INCREMENTAL
# -----------------------------------------------------------------------------
# Cron schedule para sync (formato: "0 22 * * 0" = Domingo 22h)
SYNC_CRON_SCHEDULE=0 22 * * 0

# Janela de sync em dias
SYNC_WINDOW_DAYS=7

# Overlap em dias para não perder dados
SYNC_OVERLAP_DAYS=1

# -----------------------------------------------------------------------------
# MONITORING & LOGGING
# -----------------------------------------------------------------------------
# Sentry DSN (opcional, para error tracking)
SENTRY_DSN=

# Log format (json | text)
LOG_FORMAT=text

# Log file path (vazio = apenas console)
LOG_FILE_PATH=

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=localhost,127.0.0.1

# Usuários permitidos no MVP (separados por vírgula, WhatsApp phone numbers)
ALLOWED_USERS=+5541999999999

# -----------------------------------------------------------------------------
# INFISICAL (OPCIONAL - para secrets management)
# -----------------------------------------------------------------------------
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev  # dev | staging | prod
